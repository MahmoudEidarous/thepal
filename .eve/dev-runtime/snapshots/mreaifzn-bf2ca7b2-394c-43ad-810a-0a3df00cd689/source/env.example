# Copy to .env.local and fill in.
# Supermemory Local — printed by `supermemory-server` on first boot
SUPERMEMORY_API_KEY=sm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPERMEMORY_BASE_URL=http://localhost:6767

# LLM for Recall's chat/agent/dreaming (extraction key is configured on the
# supermemory-server side separately, can be the same provider)
ANTHROPIC_API_KEY=
