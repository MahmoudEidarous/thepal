# Copy to .env.local and fill in.

# Supermemory Local — printed by `supermemory-server` on first boot
SUPERMEMORY_API_KEY=sm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPERMEMORY_BASE_URL=http://localhost:6767

# ElevenLabs — the voice. Create the agent once with
# `node scripts/create-voice-agent.mjs`, then paste the printed agent id.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# OpenRouter — powers the nightly dream agent (deepseek-v4)
OPENROUTER_API_KEY=
